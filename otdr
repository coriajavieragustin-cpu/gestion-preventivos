<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Visualizador OTDR Profesional</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root { --AZUL: #0070c0; --NARANJA: #ed7d31; --VERDE: #70ad47; --MARRON: #835c3e; }
        body { background-color: #f8f9fa; font-size: 0.85rem; }
        .navbar { background: #001f3f; color: white; margin-bottom: 20px; }
        .buffer-AZUL { background-color: var(--AZUL) !important; color: white; }
        .buffer-NARANJA { background-color: var(--NARANJA) !important; color: white; }
        .buffer-VERDE { background-color: var(--VERDE) !important; color: white; }
        .buffer-MARRON { background-color: var(--MARRON) !important; color: white; }
        .loss-alert { background-color: #ffccd2 !important; color: #a80000; font-weight: bold; }
        .chart-card { background: white; border-radius: 10px; padding: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); height: 350px; margin-bottom: 20px; }
        .table-card { background: white; border-radius: 10px; padding: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .table-scroll { max-height: 500px; overflow-y: auto; }
        th { position: sticky; top: 0; background: #212529 !important; color: white; z-index: 5; }
        tr:hover { cursor: pointer; background-color: #f1f8ff !important; }
        tr.selected { background-color: #e3f2fd !important; outline: 2px solid #007bff; }
    </style>
</head>
<body>

<nav class="navbar p-3 shadow">
    <div class="container-fluid">
        <span class="fw-bold">Gestión OTDR - Auditoría de Red</span>
        <select id="sheetSelector" class="form-select w-auto" onchange="fetchData()"></select>
    </div>
</nav>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="chart-card">
                <canvas id="otdrChart"></canvas>
            </div>
        </div>
        <div class="col-12">
            <div class="table-card">
                <div class="table-scroll">
                    <table class="table table-sm table-bordered">
                        <thead id="tableHead"></thead>
                        <tbody id="tableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbyyTaNUwXgNmJfWIqHbwaAONuHGc_6-3igk9pDM29Do2U_G0bdVrMEKPUpG8sJ_WWe8Rw/exec'; // <--- PEGA TU URL DE APPS SCRIPT AQUÍ
    let chart;

    async function init() {
        try {
            const resp = await fetch(`${WEB_APP_URL}?action=getSheets`);
            const names = await resp.json();
            const sel = document.getElementById('sheetSelector');
            sel.innerHTML = '';
            names.forEach(n => { const o = document.createElement('option'); o.value = o.text = n; sel.add(o); });
            
            initChart();
            fetchData();
        } catch(e) { alert("Error de conexión con la API de Google"); }
    }

    function initChart() {
        const ctx = document.getElementById('otdrChart').getContext('2d');
        chart = new Chart(ctx, {
            type: 'line',
            data: { labels: [], datasets: [{ 
                label: 'Pérdida (dB)', 
                data: [], 
                borderColor: '#333', 
                borderWidth: 3,
                tension: 0.2, 
                fill: false, 
                pointRadius: 5,
                spanGaps: true // Permite conectar puntos aunque haya valores nulos (OK/Reflex)
            }] },
            options: { 
                responsive: true, 
                maintainAspectRatio: false, 
                scales: { y: { reverse: true, suggestedMin: 0, title: { display: true, text: 'Atenuación (dB)' } } } 
            }
        });
    }

    async function fetchData() {
        const sheet = document.getElementById('sheetSelector').value;
        const resp = await fetch(`${WEB_APP_URL}?action=getData&name=${encodeURIComponent(sheet)}`);
        const data = await resp.json();
        if (data.length > 0) renderTable(data);
    }

    function renderTable(data) {
        const thead = document.getElementById('tableHead');
        const tbody = document.getElementById('tableBody');
        const faKeys = Object.keys(data[0].mediciones);

        thead.innerHTML = `<tr><th>Buffer</th><th>Pelo</th><th>Ramal</th>${faKeys.map(k => `<th>${k.split(' ')[0]}</th>`).join('')}</tr>`;
        tbody.innerHTML = '';

        data.forEach(row => {
            const tr = document.createElement('tr');
            tr.onclick = () => {
                document.querySelectorAll('tr').forEach(r => r.classList.remove('selected'));
                tr.classList.add('selected');
                updateChart(row, faKeys);
            };
            
            let cells = `<td class="buffer-${row.buffer} text-center fw-bold">${row.buffer}</td>`;
            cells += `<td class="text-center">${row.pelo}</td><td class="small">${row.ramal}</td>`;
            
            faKeys.forEach(k => {
                const val = row.mediciones[k];
                const isBad = (typeof val === 'number' && val > 0.5);
                cells += `<td class="text-center ${isBad ? 'loss-alert' : ''}">${val || ''}</td>`;
            });

            tr.innerHTML = cells;
            tbody.appendChild(tr);
        });
    }

    function updateChart(row, keys) {
        chart.data.labels = keys.map(k => k.split(' ')[0]);
        // Solo pasamos números al gráfico, lo demás (OK, Reflex, null) se envía como null
        chart.data.datasets[0].data = keys.map(k => typeof row.mediciones[k] === 'number' ? row.mediciones[k] : null);
        chart.data.datasets[0].label = `Pelo ${row.pelo} (${row.buffer}) - ${row.ramal}`;
        
        const colors = { 'AZUL': '#0070c0', 'NARANJA': '#ed7d31', 'VERDE': '#70ad47', 'MARRON': '#835c3e' };
        chart.data.datasets[0].borderColor = colors[row.buffer] || '#333';
        chart.update();
    }

    window.onload = init;
</script>
</body>
</html>
