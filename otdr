<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auditoría Integral OTDR - GitHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root { --AZUL: #0070c0; --NARANJA: #ed7d31; --VERDE: #70ad47; --MARRON: #835c3e; --GRIS: #7b7b7b; }
        body { background-color: #f4f6f9; font-size: 0.85rem; }
        .navbar { background: #0d47a1; color: white; }
        .buffer-AZUL { background-color: var(--AZUL) !important; color: white; }
        .buffer-NARANJA { background-color: var(--NARANJA) !important; color: white; }
        .buffer-VERDE { background-color: var(--VERDE) !important; color: white; }
        .buffer-MARRON { background-color: var(--MARRON) !important; color: white; }
        .loss-alert { background-color: #ffc7ce !important; color: #9c0006; font-weight: bold; }
        .table-container { background: white; border-radius: 8px; padding: 15px; margin: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        th { background-color: #212529 !important; color: white; text-align: center; white-space: nowrap; }
        .sticky-col { position: sticky; left: 0; z-index: 5; background: white; }
    </style>
</head>
<body>

<nav class="navbar p-3 shadow">
    <div class="container-fluid">
        <span class="fw-bold">Gestión de Certificaciones OTDR</span>
        <select id="sheetSelector" class="form-select w-auto" onchange="fetchData()"></select>
    </div>
</nav>

<div class="table-container">
    <div class="table-responsive">
        <table class="table table-sm table-bordered align-middle">
            <thead id="tableHead">
                </thead>
            <tbody id="tableBody">
                </tbody>
        </table>
    </div>
</div>

<script>
    const WEB_APP_URL = 'https://script.google.com/macros/s/AKfycbxFCmoLi1swMQFOvi4zHewdji5Aa_8RiOgRotHu7pg0VpNs0_Wx66Fwnu0cXFztBlRIEA/exec'; // <--- PEGA TU URL AQUÍ

    async function init() {
        const response = await fetch(`${WEB_APP_URL}?action=getSheets`);
        const names = await response.json();
        const selector = document.getElementById('sheetSelector');
        names.forEach(name => {
            const opt = document.createElement('option');
            opt.value = opt.textContent = name;
            selector.appendChild(opt);
        });
        fetchData();
    }

    async function fetchData() {
        const sheetName = document.getElementById('sheetSelector').value;
        const response = await fetch(`${WEB_APP_URL}?action=getData&name=${encodeURIComponent(sheetName)}`);
        const data = await response.json();
        renderTable(data);
    }

    function renderTable(data) {
        if (!data.length) return;
        
        const thead = document.getElementById('tableHead');
        const tbody = document.getElementById('tableBody');
        
        // 1. Generar Encabezados dinámicos
        const faKeys = Object.keys(data[0].mediciones);
        thead.innerHTML = `
            <tr>
                <th class="sticky-col">Buffer</th>
                <th>Pelo</th>
                <th>Puerto</th>
                <th>Ramal</th>
                ${faKeys.map(k => `<th>${k}</th>`).join('')}
                <th>Estado</th>
            </tr>
        `;

        // 2. Generar Filas
        tbody.innerHTML = '';
        data.forEach(row => {
            const tr = document.createElement('tr');
            
            // Lógica de validación: si CUALQUIER medición FA es > 0.5
            let hasError = false;
            let medicionesHtml = '';
            
            faKeys.forEach(k => {
                const val = parseFloat(String(row.mediciones[k]).replace(',', '.'));
                const alertClass = val > 0.5 ? 'loss-alert' : '';
                if (val > 0.5) hasError = true;
                medicionesHtml += `<td class="text-center ${alertClass}">${row.mediciones[k] || '-'}</td>`;
            });

            tr.innerHTML = `
                <td class="buffer-${row.buffer} text-center fw-bold sticky-col">${row.buffer}</td>
                <td class="text-center">${row.pelo}</td>
                <td class="text-center">${row.puerto}</td>
                <td class="small"><strong>${row.ramal}</strong></td>
                ${medicionesHtml}
                <td class="text-center fw-bold ${hasError ? 'text-danger' : 'text-success'}">
                    ${hasError ? '⚠ FALLA' : '✔ OK'}
                </td>
            `;
            tbody.appendChild(tr);
        });
    }

    window.onload = init;
</script>
</body>
</html>
